{
  "name": "divineconnect-backend",
  "version": "1.0.0",
  "description": "DivineConnect backend API - Node + Express + PostgreSQL",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:init": "node src/scripts/initDb.js",
    "db:seed": "node src/scripts/seedTemples.js",
    "db:setup": "npm run db:init && npm run db:seed"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "suncalc": "^1.9.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
